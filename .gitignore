*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# MonoDevelop/Xamarin
*.userprefs

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio
.vs/
Generated\ Files/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Cache files
ipch/
*.opendb
*.VC.db
*.VC.VC.opendb

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Azure-related
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/
csx/
*.build.csdef

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Node modules
node_modules/

# AppPackages
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt

# SQL Server
*.mdf
*.ldf
*.ndf

# Backups
*.bak
_UpgradeReport_Files/
Backup*/

# Others
*.pfx
*.publishsettings
*.jfm
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# JetBrains Rider
.idea/
*.sln.iml

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Python cache (if using Python tooling)
__pycache__/
*.pyc

# Secrets & Appsettings
appsettings.Development.json
appsettings.Production.json
appsettings.*.json
!appsettings.json
secrets.json
*.secrets.json

# EF Migrations (OPTIONAL — uncomment to ignore migrations)
# Migrations/
